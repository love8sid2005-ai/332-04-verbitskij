@startuml

start

:Открытие главного экрана;

if (Данные загружены?) then (Нет)
    :Показать индикатор загрузки;
else (Да)
    if (Есть активная задача?) then (Да)
        :Показать карточку активной задачи;
    else (Нет)
        :Показать приветствие и прогресс;
    endif
endif

if (Есть просроченные задачи?) then (Да)
    :Показать список просроченных задач;
endif

if (Есть задачи на сегодня?) then (Да)
    :Показ списка задач;
else (Нет)
    :Показ сообщения о пустом списке;
    :Пользователь нажимает "Добавить задачу";
    stop
endif

if (Пользователь нажал?) then (На задачу)
    if (Просрочена?) then (Да)
        :Открыть меню опций;
    else (Нет)
        :Переход на экран прогресса задачи;
        stop
    endif
else (На "...") 
    :Открыть меню опций;
endif

if (Выбран вариант?) then (Редактировать)
    :Переход на экран редактирования;
    stop
elseif (Удалить)
    :Удаление задачи;
    stop
elseif (Перенести)
    :Перенос задачи;
    stop
else (Завершить)
    :Отметка задачи выполненной;
    stop
endif

@enduml

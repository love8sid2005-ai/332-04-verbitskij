@startuml
!define MAIN_ENTITY #9FE2BF-4CBB17
!define ACTOR_COLOR #FF7F50-FF4500
!define SYSTEM_COLOR #6495ED-4169E1
!define USECASE_COLOR #FFD700-FF8C00

skinparam {
  BackgroundColor #1E1E1E
  ArrowColor #FFFFFF
  ActorBorderColor #FFFFFF
  UsecaseBorderColor #FFFFFF
  UsecaseBackgroundColor MAIN_ENTITY
  ActorBackgroundColor ACTOR_COLOR
}

skinparam actor {
  BackgroundColor<< Пользователь >> ACTOR_COLOR
  BackgroundColor<< Администратор >> #40E0D0-20B2AA
  BackgroundColor<< API >> #DA70D6-9932CC
  FontColor #FFFFFF
  FontStyle Bold
  BorderColor #FFFFFF
}

skinparam usecase {
  BackgroundColor USECASE_COLOR
  BorderColor #FF4500
  FontColor #000000
  FontStyle Bold
}

actor "👤 Пользователь" as User << Пользователь >>
actor "🛠️ Администратор" as Admin << Администратор >>
actor "🌐 Внешний API" as API << API >>

rectangle "💱 <b>Система мониторинга курсов валют</b>" as System {
  usecase "📊 <b>Просмотр текущих курсов</b>" as UC1
  usecase "🔄 <b>Конвертировать валюту</b>" as UC2
  usecase "📈 <b>Анализ исторических данных</b>" as UC3
  usecase "🔔 <b>Умные уведомления</b>" as UC4
  usecase "⚡ <b>Автообновление курсов</b>" as UC5
  usecase "👥 <b>Управление пользователями</b>" as UC6
  usecase "🔧 <b>Настройка источников</b>" as UC7
  usecase "📱 <b>Экспорт данных</b>" as UC8
}

' Связи пользователя
User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC8

' Связи администратора
Admin --> UC5
Admin --> UC6
Admin --> UC7
Admin --> UC3

' Связи API
API --> UC5

' Включения и расширения
UC1 .> UC5 : <<include>>
UC2 .> UC1 : <<include>>
UC3 .> UC5 : <<include>>
UC4 .> UC1 : <<extend>>
UC8 .> UC3 : <<extend>>

note right of System
  <b>💎 Премиум система</b>
  • Реальное время
  • AI-прогнозы
  • Мульти-источники
  • Безопасность
end note

note top of UC4
  🔔 <b>Умные уведомления</b>
  • По пороговым значениям
  • Трендовые оповещения
  • Push & Email
end note
@enduml